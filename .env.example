# ── Database ────────────────────────────────────────────────────────────────
# Used by docker-compose to create the postgres container AND by the server.
POSTGRES_USER=gatewanderers
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=gatewanderers

# Full connection string — docker-compose overrides this automatically.
# Only set manually if running the server binary directly (outside Docker).
# DATABASE_URL=postgres://gatewanderers:CHANGE_ME@localhost:5432/gatewanderers?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────────────────────
# 32-byte random key, encoded as 64 hex characters.
# Generate: openssl rand -hex 32
PASETO_KEY=d237c23be67af215da190eff819e3405e698bfe1902578d2f762499f1a3cd36d

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# Tick interval (how often the game engine runs). Default: 60s
# Use shorter intervals for playtesting: 10s, 15s
TICK_INTERVAL=60s
